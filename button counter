from tkinter import *

count = 0
def click():
    global count
    count += 1
    label.config(text = count)

window = Tk()
button = Button(window, text = "Click me")
button.config(command=click) #performs call back of function
button.config(font=("Times New Roman", 50, 'italic'))
button.config(bg = '#D16BAF')
button.config(fg = '#962A15') #bg-background fg-font
button.config(activebackground = "#FF0000") #when u click on the button, it chaanges to red
button.config(activeforeground = "#962A15")
#to add image:
#image = PhotoImage(file="./images/button.png")
#button.config(image=image)
#button.config(compound = 'top') #places picture on top
#button.config(state = DISABLED) #disables the button (active/disabled)
label = Label(window, text = count ) #to display it not in the terminal
label.config(font=("Times New Roman", 50))
label.pack()
button.pack() #to pack it  to the window
window.mainloop()
